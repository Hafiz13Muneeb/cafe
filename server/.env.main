# ============================================
# 🚀 Cafe Menu Backend - Environment Variables
# ============================================

# ---------- Server ----------
# Port on which the server runs
PORT=5000

# --------------------------------------------
# Branding (used in email templates)
# --------------------------------------------
BRAND_NAME=CafeFlow

# Node environment: 'development' or 'production'
NODE_ENV=development

# ---------- Database ----------
# MongoDB connection string (use your own URI)
# Can also be MONGODB_URI or MONGO_URL
MONGO_URI=mongodb://localhost:27017/cafe

# ---------- JWT ----------
# Secret key for signing JSON Web Tokens (generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# ---------- Cloudinary (for image uploads) ----------
# Cloudinary cloud name, API key, and API secret
# Get these from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=dqsyxtggn
CLOUDINARY_API_KEY=963679766551132
CLOUDINARY_API_SECRET=Bt4U5kHcGRR1M2Vc_BdC7mEIvhE

# ---------- Optional ----------
# Rate limiting: maximum requests per 15 minutes (default: 100)
RATE_LIMIT_MAX=100

# Client URL for CORS (default: http://localhost:5173)
CLIENT_URL=http://localhost:5173


